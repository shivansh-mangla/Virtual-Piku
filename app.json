{
  "expo": {
    "name": "virtualPiku",
    "slug": "virtualPiku",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bunny.png",
    "scheme": "virtualpiku",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/bunny.png",
        "backgroundImage": "./assets/images/bunny.png",
        "monochromeImage": "./assets/images/bunny.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.shivansh_mangla.virtualPiku"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/bunny.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/bunny.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ec879e7-5be5-433e-a08e-7bcc35202fe7"
      }
    }
  }
}
